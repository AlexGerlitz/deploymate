DOMAIN=deploymate.example.com
NEXT_PUBLIC_API_BASE_URL=/api
NEXT_PUBLIC_LOCAL_DEPLOYMENTS_ENABLED=0
NEXT_PUBLIC_PUBLIC_SIGNUP_ENABLED=1
NEXT_PUBLIC_BUSINESS_CONTACT_EMAIL=founder@deploymate.example.com

POSTGRES_DB=deploymate
POSTGRES_USER=deploymate
POSTGRES_PASSWORD=change-this-postgres-password
DATABASE_URL=postgresql://deploymate:change-this-postgres-password@postgres:5432/deploymate

DEPLOYMATE_ADMIN_USERNAME=admin
DEPLOYMATE_ADMIN_PASSWORD=change-this-admin-password
DEPLOYMATE_SERVER_CREDENTIALS_KEY=replace-with-fernet-key

SESSION_COOKIE_SECURE=true
DEPLOYMATE_SESSION_TTL_SECONDS=604800
DEPLOYMATE_AUTH_RATE_LIMIT_ATTEMPTS=5
DEPLOYMATE_AUTH_RATE_LIMIT_WINDOW_SECONDS=60
DEPLOYMATE_AUTH_RATE_LIMIT_BACKEND=database
CORS_ALLOW_ORIGINS=https://deploymate.example.com
DEPLOYMATE_LOCAL_DOCKER_ENABLED=false
DEPLOYMATE_PUBLIC_SIGNUP_ENABLED=true
DEPLOYMATE_SSH_HOST_KEY_CHECKING=yes
DEPLOYMATE_SSH_KNOWN_HOSTS_FILE=/opt/deploymate/.secrets/deploymate_known_hosts
# DEPLOYMATE_ALLOW_INSECURE_DEFAULT_ADMIN=true
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
