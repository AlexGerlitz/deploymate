DOMAIN=deploymate.example.com
NEXT_PUBLIC_API_BASE_URL=/api
NEXT_PUBLIC_LOCAL_DEPLOYMENTS_ENABLED=0
NEXT_PUBLIC_PUBLIC_SIGNUP_ENABLED=1

POSTGRES_DB=deploymate
POSTGRES_USER=deploymate
POSTGRES_PASSWORD=change-this-postgres-password
DATABASE_URL=postgresql://deploymate:change-this-postgres-password@postgres:5432/deploymate

DEPLOYMATE_ADMIN_USERNAME=admin
DEPLOYMATE_ADMIN_PASSWORD=change-this-admin-password

SESSION_COOKIE_SECURE=true
CORS_ALLOW_ORIGINS=https://deploymate.example.com
DEPLOYMATE_LOCAL_DOCKER_ENABLED=false
DEPLOYMATE_PUBLIC_SIGNUP_ENABLED=true
DEPLOYMATE_SSH_HOST_KEY_CHECKING=accept-new
# DEPLOYMATE_SSH_KNOWN_HOSTS_FILE=/data/deploymate_known_hosts
